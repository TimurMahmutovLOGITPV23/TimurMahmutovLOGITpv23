ALTER TABLE Category ADD CONSTRAINT CategoryNimetus UNIQUE (CategoryNimetus);


--Product (idProduct, Name, idCategory, Price)
CREATE TABLE Products(
idProduct int PRIMARY KEY identity(1,1),
ProductNimetus varchar (20) not null,
idCategory int, FOREIGN KEY (idCategory) REFERENCES Category(idCategory),
Price money);
